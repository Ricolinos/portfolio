# Cotizador: envío de leads por correo (https://resend.com/api-keys)
RESEND_API_KEY=re_your_api_key_here
# Destinatario de las solicitudes de cotización (opcional; default: ricardo@ricolinos.com)
# QUOTE_TO_EMAIL=tu@correo.com

# ── Sync Clerk → Prisma (src/app/api/webhooks/clerk/route.ts) ──────────────
# Signing Secret del endpoint en Clerk Dashboard → Webhooks (eventos
# user.created / user.updated / user.deleted, apuntando a /api/webhooks/clerk)
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_signing_secret_here

# ── Agent Studio (scripts/agent-studio.ts) ──────────────────────────────────
# API key de Anthropic (https://platform.claude.com) — requerida
ANTHROPIC_API_KEY=sk-ant-your_api_key_here
# Modelo a usar (opcional; default: claude-opus-4-8)
# AGENT_MODEL=claude-opus-4-8
# Máx. turnos del agentic loop por agente (opcional; default: 40)
# AGENT_MAX_TURNS=40
# Máx. reintentos del bucle de autocorrección de typecheck (opcional; default: 5)
# AGENT_MAX_FIX_ATTEMPTS=5