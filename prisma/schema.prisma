// Prisma 7: las URLs de conexión viven fuera del schema.
// - CLI/migraciones → prisma.config.ts (DIRECT_URL, conexión directa)
// - Runtime/app → src/lib/prisma.ts vía adapter (DATABASE_URL, pooler)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Sincronizado con Clerk: el id es el userId de Clerk (user_xxx)
model User {
  id        String   @id
  email     String   @unique
  username  String?  @unique
  name      String?
  imageUrl  String?
  role      String   @default("client")
  whatsapp  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes       ProjectQuote[]
  mediaFiles   MediaFile[]
  integrations CloudIntegration[]
  exercises    MarkdownExercise[]
}

model ProjectQuote {
  id         String   @id @default(cuid())
  title      String
  clientName String?
  status     String   @default("draft")
  currency   String   @default("MXN")
  total      Decimal? @db.Decimal(12, 2)
  // Arrays/matrices de costos dinámicos de las tablas de cálculo
  calculationData Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MarkdownExercise {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  // String puro del archivo .md
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model MediaFile {
  id        String   @id @default(cuid())
  fileName  String
  fileType  String
  // URL pública o firmada de Supabase Storage
  fileUrl   String
  // Bytes
  fileSize  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum CloudProvider {
  GOOGLE_DRIVE
  ONEDRIVE
  GOOGLE_CALENDAR
  DROPBOX
  OTHER
}

model CloudIntegration {
  id        String        @id @default(cuid())
  provider  CloudProvider
  isActive  Boolean       @default(true)
  // Configuración/estado de la conexión externa
  metaData  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
