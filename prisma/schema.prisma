// Prisma 7: las URLs de conexión viven fuera del schema.
// - CLI/migraciones → prisma.config.ts (DIRECT_URL, conexión directa)
// - Runtime/app → src/lib/prisma.ts vía adapter (DATABASE_URL, pooler)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Sincronizado con Clerk: el id es el userId de Clerk (user_xxx)
model User {
  id        String   @id
  email     String   @unique
  username  String?  @unique
  name      String?
  imageUrl  String?
  role      String   @default("client")
  whatsapp  String?
  // Perfil editable por el cliente desde /[username]
  secondaryEmail String?
  address        String?
  company        String?
  brand          String?
  // Lema corto (máx. 15 palabras, validado en la server action)
  motto          String?
  // Portada del perfil de Partner (data URL comprimida, validada en la server action)
  coverImageUrl  String?
  // Visibilidad del Partner en Explorar/designerds; el perfil directo por
  // username sigue siendo accesible aunque sea privado
  isPublic       Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes       ProjectQuote[]
  mediaFiles   MediaFile[]
  integrations CloudIntegration[]
  exercises    MarkdownExercise[]
  portfolio    PortfolioPiece[]
}

// Pieza de portafolio publicada por un partner. Respalda el showcase del
// perfil /[username], HomeShowcase y ExploreFeed (antes mocks).
model PortfolioPiece {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  category    String
  // URL pública (Supabase Storage o /images locales); galería opcional de URLs
  coverUrl    String
  gallery     Json?
  location    String?
  views       Int      @default(0)
  likes       Int      @default(0)
  // Visibilidad: false = borrador, solo visible para el dueño
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model ProjectQuote {
  id         String   @id @default(cuid())
  title      String
  clientName String?
  status     String   @default("draft")
  currency   String   @default("MXN")
  total      Decimal? @db.Decimal(12, 2)
  // Arrays/matrices de costos dinámicos de las tablas de cálculo
  calculationData Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MarkdownExercise {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  // String puro del archivo .md
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model MediaFile {
  id        String   @id @default(cuid())
  fileName  String
  fileType  String
  // URL pública o firmada de Supabase Storage
  fileUrl   String
  // Bytes
  fileSize  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum CloudProvider {
  GOOGLE_DRIVE
  ONEDRIVE
  GOOGLE_CALENDAR
  DROPBOX
  OTHER
}

model CloudIntegration {
  id        String        @id @default(cuid())
  provider  CloudProvider
  isActive  Boolean       @default(true)
  // Configuración/estado de la conexión externa
  metaData  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
