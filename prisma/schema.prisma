// Prisma 7: las URLs de conexión viven fuera del schema.
// - CLI/migraciones → prisma.config.ts (DIRECT_URL, conexión directa)
// - Runtime/app → src/lib/prisma.ts vía adapter (DATABASE_URL, pooler)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Sincronizado con Clerk: el id es el userId de Clerk (user_xxx)
model User {
  id                String    @id
  email             String    @unique
  username          String?   @unique
  name              String?
  imageUrl          String?
  role              String    @default("client")
  whatsapp          String?
  // Opt-in del colaborador para exponer su WhatsApp en su perfil público.
  // Default false: privado hasta que el propio usuario decida compartirlo, y
  // aun así solo visible a otros usuarios logueados de la plataforma (nunca
  // a visitantes anónimos). Ver src/app/[username]/page.tsx.
  shareWhatsapp     Boolean   @default(false)
  // Perfil editable por el cliente desde /[username]
  secondaryEmail    String?
  address           String?
  company           String?
  brand             String?
  // Lema corto (máx. 40 caracteres, validado en la server action)
  motto             String?
  // Portada del perfil de Partner (data URL comprimida, validada en la server action)
  coverImageUrl     String?
  // Visibilidad del Partner en Explorar/designerds; el perfil directo por
  // username sigue siendo accesible aunque sea privado
  isPublic          Boolean   @default(true)
  // Imagen destacada de la tarjeta Designerd en Explorar (data URL comprimida,
  // mismo patrón que coverImageUrl)
  featuredImageUrl  String?
  // Cita/blockquote mostrada sobre la imagen de la tarjeta Designerd
  cardQuote         String?
  // Puesto/título profesional del Partner (ej. "Diseñador de Marca")
  headline          String?
  // Breve descripción para el reverso de la tarjeta Designerd
  bio               String?
  // Preferencia de contacto del cliente: "whatsapp" | "email"
  contactPreference String?
  // Horario preferido de contacto (texto corto, ej. "L-V 9:00-18:00")
  contactHours      String?
  website           String?
  // Giro o industria del negocio del cliente
  industry          String?
  // Matriz de roles del Partner (Fase 4): rol principal y hasta 2 roles
  // secundarios. Máx. 2 secundarios, validado en la server action, no en el schema.
  primaryRole       String?
  secondaryRoles    String[]  @default([])
  // Presencia del messenger (heartbeat del cliente cada ~60s vía
  // presenceHeartbeat): null = nunca reportó actividad. La derivación a
  // online/busy/offline vive en src/lib/presence.ts (derivePresence).
  lastSeenAt        DateTime?
  // Estado manual de presencia: null = automático (según lastSeenAt);
  // "busy" = ocupado, fijado a mano por el propio usuario.
  presenceStatus    String?
  // Personalización de apariencia del perfil de Partner (/[username] y
  // tarjeta Designerd en /explorar/designerds). null = default de la marca.
  // Whitelists exactas validadas en la server action (updateProfileAppearance).
  profileBrand      String?
  profileAccent     String?
  profileNeutral    String?
  profileBorder     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  quotes       ProjectQuote[]
  mediaFiles   MediaFile[]
  integrations CloudIntegration[]
  exercises    MarkdownExercise[]
  portfolio    PortfolioPiece[]

  clientConnections     Connection[]          @relation("clientConnections")
  partnerConnections    Connection[]          @relation("partnerConnections")
  resources             ClientResource[]      @relation("clientResources")
  projectCollaborations ProjectCollaborator[] @relation("projectCollaborations")
  sentMessages          Message[]             @relation("sentMessages")

  // Subsistema de mensajería/tareas del chat (Fase 1: chat-requirements.md)
  startedThreads       DirectThread[]          @relation("startedThreads")
  receivedThreads      DirectThread[]          @relation("receivedThreads")
  sentDirectMessages   DirectMessage[]         @relation("sentDirectMessages")
  sentChannelMessages  ChannelMessage[]        @relation("sentChannelMessages")
  projectRoles         ProjectRoleAssignment[] @relation("projectRoles")
  assignedTasks        ProjectTask[]           @relation("assignedTasks")
  notifications        Notification[]          @relation("notifications")
  // Control de acceso por sala (canales restringidos, ver ChannelMember)
  channelMemberships   ChannelMember[]         @relation("channelMemberships")
  // Responsable asignado a tareas de activos (checklist de ProjectAsset)
  assetTaskAssignments AssetTaskAssignee[]     @relation("assetTaskAssignments")

  // Brief-hub: convocatorias (concursos creativos) creadas por el cliente y
  // postulaciones enviadas por el partner (ver Contest/ContestApplication)
  clientContests      Contest[]            @relation("clientContests")
  contestApplications ContestApplication[] @relation("contestApplications")
}

// Pieza de portafolio publicada por un partner. Respalda el showcase del
// perfil /[username], HomeShowcase y ExploreFeed (antes mocks).
model PortfolioPiece {
  id               String    @id @default(cuid())
  title            String
  description      String?   @db.Text
  category         String    @default("Documento")
  // URL pública (Supabase Storage o /images locales); nula en piezas creadas
  // desde el editor de Markdown, que no requieren portada
  coverUrl         String?
  gallery          Json?
  // Adjuntos con nombre del modo Pro del editor MDX: lista de
  // `[{ name, url, type: "image" | "video" }]` subidos a Supabase Storage
  // (bucket portfolio-media). `name` es el identificador que el MDX usa para
  // referenciar el archivo sin exponer su URL en el texto. Distinto de
  // `gallery` (legacy, string[] de data URLs sin nombre).
  attachments      Json?
  location         String?
  views            Int       @default(0)
  likes            Int       @default(0)
  // Visibilidad: false = borrador, solo visible para el dueño
  isPublic         Boolean   @default(true)
  // Fuente Markdown del editor propio del Partner (texto plano). Distinta del
  // caso de estudio MDX por archivo en src/content/portfolio.
  markdownContent  String?   @db.Text
  // Bloques estructurados del Canvas (ContentBlock[]), tal cual los arma el
  // editor. blocksToMarkdown() no tiene inversa: sin esto, reabrir una pieza
  // para editarla no podría reconstruir sus secciones desde el Markdown ya
  // serializado.
  contentBlocks    Json?
  downloadUrl      String?
  resourcePassword String?
  // Panel "Editar proyecto": máx. 5, validado en la server action.
  // LEGACY: se conserva por compatibilidad con piezas viejas; el editor
  // nuevo usa `subcategories` (taxonomía libre, mín. 1 al publicar).
  tags             String[]  @default([])
  // Subcategorías libres de la pieza (ej. "Logotipo", "Storyboard"), máx. 10,
  // validadas en la server action. Al menos 1 es obligatoria para publicar
  // (isPublic true); los borradores pueden quedar sin ninguna.
  subcategories    String[]  @default([])
  // Software/herramientas usadas en la pieza (ej. "Photoshop", "Blender"),
  // máx. 15, validadas en la server action. Colorea etiquetas en la UI vía
  // src/lib/pieceCategories.ts (softwareTagVariant).
  software         String[]  @default([])
  // Usernames de colaboradores, sin relación formal ni validación todavía
  collaborators    String[]  @default([])
  // Fecha opcional de lanzamiento/publicación, distinta de createdAt
  releaseDate      DateTime?
  // Caso de estudio creado desde el panel: slug de la ruta
  // /<username>/proyecto/<slug> y MDX completo (frontmatter + cuerpo).
  // Piezas antiguas lo dejan en null (su caso de estudio vive en archivo).
  slug             String?
  caseStudy        String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId])
  @@index([category])
}

model ProjectQuote {
  id              String   @id @default(cuid())
  title           String
  clientName      String?
  status          String   @default("draft")
  currency        String   @default("MXN")
  total           Decimal? @db.Decimal(12, 2)
  // Arrays/matrices de costos dinámicos de las tablas de cálculo
  calculationData Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MarkdownExercise {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  // String puro del archivo .md
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model MediaFile {
  id        String   @id @default(cuid())
  fileName  String
  fileType  String
  // URL pública o firmada de Supabase Storage, o /api/media/<id> cuando los
  // bytes viven en la columna `data` (imágenes de casos de estudio, sin bucket)
  fileUrl   String
  // Bytes
  fileSize  Int
  // Contenido base64 (sin prefijo data:) servido por /api/media/[id].
  // Workaround por falta de bucket de Storage; null para archivos externos.
  data      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum CloudProvider {
  GOOGLE_DRIVE
  ONEDRIVE
  GOOGLE_CALENDAR
  DROPBOX
  OTHER
}

model CloudIntegration {
  id        String        @id @default(cuid())
  provider  CloudProvider
  isActive  Boolean       @default(true)
  // Configuración/estado de la conexión externa
  metaData  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// Solicitud de contacto cliente → partner; al aceptarse habilita proyectos conjuntos
model Connection {
  id                    String                @id @default(cuid())
  status                ConnectionStatus      @default(PENDING)
  message               String?               @db.Text
  clientId              String
  client                User                  @relation("clientConnections", fields: [clientId], references: [id], onDelete: Cascade)
  partnerId             String
  partner               User                  @relation("partnerConnections", fields: [partnerId], references: [id], onDelete: Cascade)
  projects              CollabProject[]
  // Colaboradores adicionales agregados a un CollabProject vía esta Connection
  // (ver ProjectCollaborator); el partner "fundador" de la Connection no
  // necesita una fila aquí, ya está implícito en Connection.partnerId.
  projectCollaborations ProjectCollaborator[]
  messages              Message[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@unique([clientId, partnerId])
  @@index([partnerId])
}

// Proyecto conjunto entre el cliente y el partner de una Connection aceptada
model CollabProject {
  id              String                  @id @default(cuid())
  title           String
  description     String?                 @db.Text
  status          String                  @default("active") // active | completed | archived
  // Notas/configuración editables por el cliente
  clientNotes     String?                 @db.Text
  // Cotización y calendario del borrador; editables por ambas partes
  quoteAmount     Decimal?                @db.Decimal(12, 2)
  quoteCurrency   String                  @default("MXN")
  quoteNotes      String?                 @db.Text
  startDate       DateTime?
  dueDate         DateTime?
  // Imagen corporativa/logotipo del proyecto (data URL comprimida o URL
  // pública, mismo patrón que User.coverImageUrl)
  logoUrl         String?
  // Categorización del proyecto (panel de administración), validada contra
  // src/lib/projectTypes.ts (árbol extraído del Cotizador)
  projectType     String?
  projectSubtype  String?
  connectionId    String
  connection      Connection              @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  tasks           ProjectTask[]
  links           ProjectLink[]
  assets          ProjectAsset[]
  // Colaboradores ADICIONALES al partner "fundador" de la Connection (ej.
  // otros diseñadores invitados a este proyecto en particular).
  collaborators   ProjectCollaborator[]
  // Mensajería robusta (Fase 1: chat-requirements.md) y matriz de roles
  channels        ProjectChannel[]
  roleAssignments ProjectRoleAssignment[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([connectionId])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Tarea del proyecto; el partner la marca in_review para pedir aprobación del cliente.
// Las tareas creadas desde el chat (pipeline mensaje->tarea, chat-requirements.md)
// nacen con status "pending_approval" (los valores viejos pending | in_review |
// approved siguen válidos); solo el partner asignado puede mutarlas a "approved"
// o "rejected" — se valida en la server action, no en el schema.
model ProjectTask {
  id        String        @id @default(cuid())
  title     String
  status    String        @default("pending") // pending | in_review | approved | pending_approval | rejected
  order     Int           @default(0)
  projectId String
  project   CollabProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Campos del pipeline mensaje->tarea (todos opcionales, aditivos)
  description     String?         @db.Text
  assigneeId      String?
  assignee        User?           @relation("assignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  // ID del activo del proyecto
  assetId         String?
  asset           ProjectAsset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  dueDate         DateTime?
  // Mapeo 0:1 mensaje->tarea
  sourceMessageId String?         @unique
  sourceMessage   ChannelMessage? @relation(fields: [sourceMessageId], references: [id], onDelete: SetNull)

  // Atributos ricos (Fase 6): prioridad, avance, rango de fechas y categoría
  priority  TaskPriority @default(MEDIUM)
  // Avance 0-100 para LinearGauge, validado en la server action
  progress  Int          @default(0)
  // Junto a dueDate, para DateRangePicker
  startDate DateTime?
  // Categorización personalizada libre
  category  String?

  // Dependencias cruzadas entre tareas (Fase 6)
  dependencies TaskDependency[] @relation("taskDependencies")
  dependents   TaskDependency[] @relation("dependentTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([assigneeId])
}

// Dependencia cruzada entre tareas del mismo proyecto (self-relation sobre
// ProjectTask): la tarea `task` depende de que `dependsOn` esté resuelta.
model TaskDependency {
  id          String      @id @default(cuid())
  taskId      String
  task        ProjectTask @relation("taskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnId String
  dependsOn   ProjectTask @relation("dependentTasks", fields: [dependsOnId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([taskId, dependsOnId])
  @@index([taskId])
  @@index([dependsOnId])
}

// Archivo del proyecto como link externo (la plataforma solo guarda URLs)
model ProjectLink {
  id          String            @id @default(cuid())
  label       String
  url         String
  // Detectado del hostname: drive | dropbox | onedrive | wetransfer | other
  provider    String            @default("other")
  // brand = assets de marca subidos por el cliente | final = activos finales
  // subidos por cualquier partner/colaborador. Inferido server-side, nunca
  // recibido como input del cliente (ver addProjectLink).
  type        String            @default("final") // brand | final
  // Etiqueta libre de archivo (FILE_SUBTYPES en src/lib/projectTypes.ts):
  // documento | grafico | recurso | video | otro
  subtype     String?
  addedById   String
  projectId   String
  project     CollabProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Adjunto ligado a una tarea de activo puntual (checklist de ProjectAsset)
  assetTaskId String?
  assetTask   ProjectAssetTask? @relation(fields: [assetTaskId], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())

  @@index([projectId])
  @@index([assetTaskId])
}

// Catálogo reutilizable de plantillas de activos (no pertenece a ningún
// proyecto en particular; es contenido de referencia del estudio).
model AssetCategory {
  id        String          @id @default(cuid())
  name      String          @unique // "Branding"
  order     Int             @default(0)
  templates AssetTemplate[]
}

model AssetTemplate {
  id            String              @id @default(cuid())
  name          String // "Logotipo"
  categoryId    String
  category      AssetCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  order         Int                 @default(0)
  taskTemplates AssetTaskTemplate[]
  projectAssets ProjectAsset[]

  @@unique([categoryId, name])
  @@index([categoryId])
}

model AssetTaskTemplate {
  id              String        @id @default(cuid())
  title           String
  order           Int           @default(0)
  assetTemplateId String
  assetTemplate   AssetTemplate @relation(fields: [assetTemplateId], references: [id], onDelete: Cascade)

  @@index([assetTemplateId])
}

// Instancia de un Activo dentro de un CollabProject real (clon editable de
// AssetTemplate en el momento de agregarlo; assetTemplateId queda como
// referencia pero el título/checklist ya son propios del proyecto).
model ProjectAsset {
  id              String             @id @default(cuid())
  title           String
  projectId       String
  project         CollabProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assetTemplateId String?
  assetTemplate   AssetTemplate?     @relation(fields: [assetTemplateId], references: [id], onDelete: SetNull)
  order           Int                @default(0)
  tasks           ProjectAssetTask[]
  // Lado inverso de ProjectTask.assetId (pipeline mensaje->tarea)
  linkedTasks     ProjectTask[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([projectId])
}

model ProjectAssetTask {
  id             String              @id @default(cuid())
  title          String
  // Booleano legado, conservado por compatibilidad; ahora derivado de status
  // (approved ⇒ true), ver updateAssetTaskDetails/resolveAssetTaskApproval.
  done           Boolean             @default(false)
  // pending | in_review | approved — mismo vocabulario que ProjectTask.status
  status         String              @default("pending")
  dueDate        DateTime?
  deliverableUrl String?
  order          Int                 @default(0)
  assetId        String
  asset          ProjectAsset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignees      AssetTaskAssignee[]
  attachments    ProjectLink[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([assetId])
}

// Responsable(s) asignado(s) a una tarea de activo (checklist de ProjectAsset)
model AssetTaskAssignee {
  id          String           @id @default(cuid())
  assetTaskId String
  assetTask   ProjectAssetTask @relation(fields: [assetTaskId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation("assetTaskAssignments", fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@unique([assetTaskId, userId])
  @@index([assetTaskId])
  @@index([userId])
}

// Colaborador ADICIONAL de un CollabProject (además del partner "fundador"
// de la Connection). Permite que varios partners participen en un mismo
// proyecto conjunto sin romper el modelo 1:1 de Connection.
model ProjectCollaborator {
  id           String        @id @default(cuid())
  projectId    String
  project      CollabProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation("projectCollaborations", fields: [userId], references: [id], onDelete: Cascade)
  connectionId String
  connection   Connection    @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  addedAt      DateTime      @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([connectionId])
}

// Asset del cliente ("Mis recursos"): link a su nube, compartible con partners elegidos
model ClientResource {
  id          String   @id @default(cuid())
  label       String
  url         String
  provider    String   @default("other")
  description String?
  // userIds (Clerk) de colaboradores con acceso (mismo patrón array que PortfolioPiece.collaborators)
  sharedWith  String[] @default([])
  ownerId     String
  owner       User     @relation("clientResources", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
}

// Mensaje directo entre cliente y partner de una Connection. El hilo vive a
// nivel Connection (no CollabProject): un cliente puede tener varios
// proyectos con el mismo partner y comparten un solo chat.
model Message {
  id           String     @id @default(cuid())
  connectionId String
  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  senderId     String
  sender       User       @relation("sentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  body         String     @db.Text
  readAt       DateTime?
  createdAt    DateTime   @default(now())

  @@index([connectionId])
  @@index([senderId])
}

// ---------------------------------------------------------------------------
// Subsistema de mensajería dual + pipeline mensaje->tarea (chat-requirements.md)
// ---------------------------------------------------------------------------

// Inbox Light: hilos 1-a-1 fuera de proyectos. Las ACLs de dirección (client
// solo inicia con partner; partner no inicia con client; partner<->partner
// libre) se validan en la server action, no en el schema.
model DirectThread {
  id          String @id @default(cuid())
  initiatorId String
  initiator   User   @relation("startedThreads", fields: [initiatorId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User   @relation("receivedThreads", fields: [recipientId], references: [id], onDelete: Cascade)

  messages DirectMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([initiatorId, recipientId])
  @@index([recipientId])
}

model DirectMessage {
  id       String       @id @default(cuid())
  threadId String
  thread   DirectThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId String
  sender   User         @relation("sentDirectMessages", fields: [senderId], references: [id], onDelete: Cascade)
  body     String       @db.Text
  readAt   DateTime?

  createdAt DateTime @default(now())

  @@index([threadId])
  @@index([senderId])
}

// Salas de chat del gestor colaborativo, 1:N con CollabProject
model ProjectChannel {
  id          String        @id @default(cuid())
  name        String
  description String?
  // Data URL comprimida, mismo patrón que User.coverImageUrl
  imageUrl    String?
  // Fuente de verdad de si la sala es restringida (reemplaza la semántica
  // implícita "tiene filas ChannelMember"): ChannelMember también guarda
  // admins de salas abiertas, así que su sola presencia ya no basta.
  restricted  Boolean       @default(false)
  projectId   String
  project     CollabProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  messages ChannelMessage[]
  // Control de acceso por sala, ver ChannelMember
  members  ChannelMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

// Control de acceso y administración por sala de proyecto. Semántica: la
// sala es restringida cuando ProjectChannel.restricted es true (acceso =
// miembro del proyecto Y (no restricted O tiene fila aquí O es el cliente
// dueño, que siempre entra)); una fila también puede existir en una sala
// abierta solo para portar el flag isAdmin. Ver requireChannelAccess en
// actions/channels.ts.
model ChannelMember {
  id        String         @id @default(cuid())
  channelId String
  channel   ProjectChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation("channelMemberships", fields: [userId], references: [id], onDelete: Cascade)
  // Admin de la sala: puede editar nombre/descripción/imagen (no eliminar).
  isAdmin   Boolean        @default(false)
  createdAt DateTime       @default(now())

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
}

model ChannelMessage {
  id        String         @id @default(cuid())
  channelId String
  channel   ProjectChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User           @relation("sentChannelMessages", fields: [senderId], references: [id], onDelete: Cascade)
  body      String         @db.Text

  // Lado inverso de la relación 0:1 ProjectTask.sourceMessageId
  task ProjectTask?

  createdAt DateTime @default(now())

  @@index([channelId])
  @@index([senderId])
}

enum ProjectMemberRole {
  PLANNER
  REALIZADOR
  DESIGNER
  EDITOR
}

// Matriz de roles del proyecto: un partner puede tener varios roles
// simultáneos en el mismo proyecto, sin duplicar el mismo rol. Solo el
// Client dueño del proyecto puede asignar/modificar (validado en la server action).
model ProjectRoleAssignment {
  id        String            @id @default(cuid())
  projectId String
  project   CollabProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation("projectRoles", fields: [userId], references: [id], onDelete: Cascade)
  role      ProjectMemberRole

  createdAt DateTime @default(now())

  @@unique([projectId, userId, role])
  @@index([projectId])
  @@index([userId])
}

enum NotificationType {
  NEW_MESSAGE
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  // Brief-hub: el partner entró a la Terna de finalistas de una convocatoria
  CONTEST_SHORTLISTED
  // Brief-hub: el partner ganó una convocatoria (fallo emitido)
  CONTEST_AWARDED
}

model Notification {
  id      String           @id @default(cuid())
  userId  String
  user    User             @relation("notifications", fields: [userId], references: [id], onDelete: Cascade)
  type    NotificationType
  // ids de canal/mensaje/tarea/proyecto relevantes al evento
  payload Json?
  readAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
}

// ---------------------------------------------------------------------------
// Brief-hub: convocatorias (concursos creativos) — modelo de dos fases anti
// spec-work. Fase 1: el partner se postula SOLO con piezas de portafolio
// existentes + pitch (ContestApplication), nunca con propuesta nueva. Fase 2:
// el cliente elige una Terna limitada (selectShortlist) que sí produce
// propuesta (ContestEntry) y cobra un fee garantizado (shortlistFee),
// independiente del resultado del fallo.
// ---------------------------------------------------------------------------

enum ContestStatus {
  DRAFT
  PUBLISHED
  SHORTLIST
  AWARDED
  CANCELLED
  BREACHED
}

enum ContestApplicationStatus {
  SUBMITTED
  SHORTLISTED
  REJECTED
  WITHDRAWN
}

enum EntryPlacement {
  WINNER
  FINALIST
  PARTICIPANT
}

// Convocatoria pública creada por un cliente.
model Contest {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  // Brief estructurado del ContentBlock[] (mismo patrón que
  // PortfolioPiece.contentBlocks)
  brief          Json?
  // Cláusulas/condiciones del concurso (derechos, entregables, etc.)
  terms          Json?
  // Categorización, validada contra src/lib/projectTypes.ts
  projectType    String?
  projectSubtype String?
  prizeAmount    Decimal       @db.Decimal(12, 2)
  currency       String        @default("MXN")
  // Fee garantizado que cobra cada finalista de la Terna, produzca o no
  // (independiente del resultado del fallo)
  shortlistFee   Decimal       @db.Decimal(12, 2)
  maxApplicants  Int?
  shortlistSize  Int           @default(5)
  applyDeadline  DateTime
  submitDeadline DateTime
  resultsDate    DateTime
  rightsPolicy   String?       @db.Text
  status         ContestStatus @default(DRAFT)

  clientId String
  client   User   @relation("clientContests", fields: [clientId], references: [id], onDelete: Cascade)

  applications ContestApplication[]

  // Id del CollabProject sembrado al fallo (awardContest); null hasta entonces
  awardedProjectId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status, applyDeadline])
}

// Postulación de un partner a una convocatoria: solo pitch + piezas de
// portafolio YA EXISTENTES (portfolioPieceIds), sin propuesta nueva.
model ContestApplication {
  id        String  @id @default(cuid())
  contestId String
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  partnerId String
  partner   User    @relation("contestApplications", fields: [partnerId], references: [id], onDelete: Cascade)

  pitch             String                   @db.Text
  portfolioPieceIds String[]                 @default([])
  status            ContestApplicationStatus @default(SUBMITTED)

  entry ContestEntry?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contestId, partnerId])
  @@index([partnerId])
}

// Propuesta real, producida solo por los finalistas de la Terna
// (ContestApplication.status = SHORTLISTED) tras selectShortlist.
model ContestEntry {
  id            String             @id @default(cuid())
  applicationId String             @unique
  application   ContestApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Bloques estructurados del Canvas (mismo patrón que
  // PortfolioPiece.contentBlocks)
  contentBlocks Json?
  coverUrl      String?
  submittedAt   DateTime?
  // null hasta el fallo (awardContest)
  placement     EntryPlacement?
  feedback      String?         @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
